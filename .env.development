# Example: Local Development Setup
# Use this for developing Puter locally

PUTER_DOMAIN=puter.localhost
SSL_ENABLED=false
PUTER_API_ROUTING=subdomain
PORT=4100
NODE_ENV=dev

# Explanation:
# - Domain: puter.localhost (accessible via http://puter.localhost:4100)
# - API: http://api.puter.localhost:4100 (subdomain mode)
# - Port: 4100 (auto port may also be used)
# - Environment: Development mode for logging and debugging

