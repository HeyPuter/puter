{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@heyputer/backend": [
        "src/backend/src/exports.ts"
      ],
      "@heyputer/backend/*": [
        "src/backend/*"
      ]
    },
    "allowJs": true,
    "checkJs": false,
    "noCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "removeComments": true,
    "noEmit": false,
    "noEmitOnError": false,
    "noImplicitAny": false
  },
  "include": [
    "src/backend/src/**/*",
    "extensions/**/*"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.mts",
    "**/*.spec.ts",
    "**/*.spec.mts",
    "**/tests/**",
    "**/node_modules/**",
    "dist/**",
    "volatile/**",
    "extensions/**/node_modules/**",
    "src/backend/vitest.config.ts",
    "src/backend/vitest.bench.config.ts",
    "src/backend/vitest.bench.config.js",
    "src/backend/src/services/worker/template/puter-portable.js",
    "src/backend/src/services/DynamoKVStore/DynamoKVStore.ts",
    "src/backend/src/clients/s3/S3Client.js",
    "src/backend/src/clients/s3/s3ClientProvider.js",
    "src/backend/src/clients/redis/RedisClient.js",
    "src/backend/src/clients/dynamodb/DDBClient.js"
  ]
}
