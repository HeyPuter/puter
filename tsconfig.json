{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "allowJs": true,
        "checkJs": false,
        "noEmit": true
    },
    "include": [
        "./src/backend",
        "./extensions",
        "src/backend/src/deprecated/filesystem/PuterS3StorageStrategy.js"
    ],
    "exclude": [
