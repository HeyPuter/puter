# Puter Environment Configuration
# This file demonstrates all available environment variables for Puter deployment
# Copy this file to .env and edit with your settings

# ============================================================
# MAIN DOMAIN CONFIGURATION (required)
# ============================================================
# The main domain where Puter will be hosted
# Examples: puter.example.com, mycloud.local, puter.localhost
PUTER_DOMAIN=puter.localhost

# ============================================================
# SSL/PROTOCOL CONFIGURATION
# ============================================================
# Enable HTTPS support (default: false)
# Set to: true, 1, yes (case-insensitive)
SSL_ENABLED=false

# ============================================================
# API ROUTING CONFIGURATION
# ============================================================
# How to route API endpoints (default: subdomain)
# Options:
#   - "subdomain" : Use api.example.com (recommended for production)
#   - "path"      : Use example.com/api (recommended for simple setups)
PUTER_API_ROUTING=subdomain

# ============================================================
# PORT CONFIGURATION
# ============================================================
# The port Puter backend listens on (default: auto)
# Set to:
#   - "auto"     : Automatically find available port (4100-4119)
#   - port number: 1-65535 (e.g., 4000, 8080)
PORT=4000

# The port exposed to clients (default: same as PORT or 80/443)
# Useful for reverse proxies or load balancers
# PUBLIC_PORT=443

# ============================================================
# SERVER CONFIGURATION
# ============================================================
# Server identifier (default: puter-server)
SERVER_ID=puter-server

# Contact email for the server (default: hey@{PUTER_DOMAIN})
# CONTACT_EMAIL=admin@example.com

# ============================================================
# ENVIRONMENT MODE
# ============================================================
# Development environment (default: dev)
# Options: dev, prod, test, staging
NODE_ENV=dev

# ============================================================
# EXAMPLE PRODUCTION SETUP
# ============================================================
# Uncomment and modify these for a production deployment:
#
# PUTER_DOMAIN=puter.example.com
# SSL_ENABLED=true
# PUTER_API_ROUTING=path
# PORT=4000
# PUBLIC_PORT=443
# NODE_ENV=production
# SERVER_ID=puter-prod-1
# CONTACT_EMAIL=admin@example.com

