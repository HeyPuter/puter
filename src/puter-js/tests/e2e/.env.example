# Copy this file to `.env` (in the same folder) and fill in your local values.
# `.env` is gitignored — never commit real credentials.

# Required: admin password from your local Puter.
# When you run `npm start` from the monorepo root, Puter prints something like:
#   ************************************************************
#   * Your default login credentials are:
#   * Username: admin
#   * Password: <hex string>
#   ************************************************************
# Copy that password here.
PUTER_ADMIN_PASSWORD=

# Optional overrides (defaults shown).
# PUTER_ADMIN_USERNAME=admin
# PUTER_TEST_ORIGIN=http://puter.localhost:4100
# PUTER_TEST_FIXTURE_ORIGIN=http://localhost:8080
