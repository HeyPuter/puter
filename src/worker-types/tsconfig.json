{
    "compilerOptions": {
        "target": "es2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "lib": ["es2022", "dom"],
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "types": ["./globals.d.ts"]
    },
    "include": [
        "index.d.ts",
        "globals.d.ts",
        "types/**/*.d.ts",
        "example/**/*.worker.ts"
    ]
}
